# ─── Server ─────────────────────────────────────────────────
PORT=9099
CORS_ALLOW_ORIGINS=*

# ─── Image uploads (legacy) ────────────────────────────────
UPLOAD_DIR=./uploads
URL_PUBLIC=http://localhost:9099

# ─── Database (PostgreSQL) ─────────────────────────────────
DATABASE_URL=postgres://dcs:dcs_pass@localhost:5432/dcs_db?sslmode=disable
JWT_SECRET=change_this_to_a_random_secret_key

# ─── Studio · Keys & Presets ──────────────────────────────
KEYS_FILE=./keys.json
PRESETS_FILE=./presets.json
OUTPUTS_DIR=./outputs
DEFAULT_MODEL=dreamina-seedance-2-0-fast-260128

# ─── Docker ────────────────────────────────────────────────
CONTAINER_NAME=dcs-back-v0

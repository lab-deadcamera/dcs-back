# ─── Server ─────────────────────────────────────────────────
PORT=9099
CORS_ALLOW_ORIGINS=*

# ─── Image uploads (legacy) ────────────────────────────────
UPLOAD_DIR=./uploads
URL_PUBLIC=http://localhost:9099
OUTPUTS_DIR=./outputs
THUMBNAIL_DIR=./thumbnails

# ─── Database (PostgreSQL) ─────────────────────────────────
DATABASE_URL=postgres://dcs:dcs_pass@localhost:5432/dcs_db?sslmode=disable
JWT_SECRET=change_this_to_a_random_secret_key

# ─── Super Admin seed credentials ──────────────────────────
SUPER_ADMIN_USERNAME=superadmin
SUPER_ADMIN_PASSWORD=change_this_to_a_strong_password

# ─── Docker ────────────────────────────────────────────────
CONTAINER_NAME=dcs-back-v0

# ─── dreamina-seedance ─────────────────────────────────────
ASSET_ACCESS_KEY_ID=tu-access-key
ASSET_SECRET_ACCESS_KEY=tu-secret-key
ASSET_DEFAULT_GROUP_ID=tu-group-id